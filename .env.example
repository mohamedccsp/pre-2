# CryptoMAESTRO Environment Variables
# Copy this file to .env and fill in the values

# OpenAI API Key (used for agent LLM calls in Phase 2+)
OPENAI_API_KEY=sk-your-key-here

# Database URL (defaults to local SQLite file)
DATABASE_URL=file:./data/cryptomaestro.db

# Secret key for MAESTRO L7 agent identity HMAC (change in production)
AGENT_SECRET_KEY=change-me-in-production

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-a-random-secret
NEXTAUTH_URL=http://localhost:3000
